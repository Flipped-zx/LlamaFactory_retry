### model
model_name_or_path: /home/develop/biocloudplantform/xxr/models/Qwen3-VL-8B-Instruct
image_max_pixels: 262144
video_max_pixels: 16384
trust_remote_code: true

### method
stage: sft
do_train: true
do_eval: true
finetuning_type: lora
lora_rank: 8
lora_target: all

### dataset
dataset: geneval2_retry_masked_multiturn_sft_train
eval_dataset: geneval2_retry_masked_multiturn_sft_val
template: qwen3_vl_nothink
cutoff_len: 32768
turn_mask: true
train_on_prompt: false
mask_history: false
packing: false
overwrite_cache: true
preprocessing_num_workers: 8
dataloader_num_workers: 2

### output
output_dir: saves/qwen3-vl-8b/lora/geneval2_retry_masked_multiturn_sft_dryrun
logging_steps: 1
save_steps: 50
eval_strategy: steps
eval_steps: 10
plot_loss: true
overwrite_output_dir: true
save_only_model: false
report_to: none

### train
per_device_train_batch_size: 1
per_device_eval_batch_size: 1
gradient_accumulation_steps: 1
gradient_checkpointing: true
learning_rate: 1.0e-4
max_steps: 50
lr_scheduler_type: cosine
warmup_ratio: 0.1
bf16: true
ddp_timeout: 180000000
resume_from_checkpoint: null
